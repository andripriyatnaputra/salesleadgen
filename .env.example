# Database Configuration
DATABASE_URL=postgres://sales:sales123@localhost:5433/salesdb?sslmode=disable
POSTGRES_PASSWORD=sales123

# Claude AI API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pengadaan.com Authentication (Optional - pilih salah satu)
# Opsi 1: Bearer token (jika tersedia)
PENGADAAN_TOKEN=your_bearer_token_here
# Opsi 2: Session cookie dari browser (recommended)
PENGADAAN_COOKIE=_ga=GA1.2.xxx; _session=xxx; connect.sid=xxx
# Opsi 3: Email/Password untuk OAuth auto-login
PENGADAAN_EMAIL=your_email@example.com
PENGADAAN_PASSWORD=your_password

# CIVD Authentication (Optional)
CIVD_USERNAME=starcom_username
CIVD_PASSWORD=starcom_password

# Email Enrichment (Optional)
HUNTER_API_KEY=your_hunter_api_key

# Production Deployment (for GitHub Actions)
# Add these as GitHub Secrets in your repository
# DEPLOY_HOST=your_server_ip
# DEPLOY_USER=deploy_user
# DEPLOY_SSH_KEY=your_private_ssh_key
